# Base de datos (Supabase Cloud, Postgres puro — sin SDK/Auth de Supabase)
DATABASE_URL=postgresql+asyncpg://postgres:REEMPLAZAR@db.xxxxxxxx.supabase.co:5432/postgres

# JWT
JWT_SECRET=REEMPLAZAR_CON_CLAVE_LARGA_ALEATORIA
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

ENV=development

# CORS — dominios del frontend permitidos, separados por coma
CORS_ORIGINS=http://localhost:3000

# Notificaciones WhatsApp — modo básico (link wa.me, sin token)
RESTAURANT_WHATSAPP_NUMBER=5215550123456

# Base pública del backend, usada para armar URLs de imágenes subidas
PUBLIC_BASE_URL=http://localhost:8000
UPLOAD_DIR=./uploads
